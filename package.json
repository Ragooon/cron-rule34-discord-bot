{
  "name": "rule34-bot",
  "version": "1.0.0",
  "description": "Discord Bot with dynamic Cronjobs using Sapphire Framework",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "npx nodemon --exec ts-node src/index.ts --ext ts",
    "db:up": "docker compose -f docker-compose.dev.yml up -d postgres redis",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d postgres redis",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@sapphire/decorators": "^6.1.0",
    "@sapphire/discord.js-utilities": "^7.3.3",
    "@sapphire/framework": "^5.2.1",
    "booru": "^2.9.0",
    "bullmq": "^5.1.0",
    "cron-validator": "^1.3.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.3.2",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.16.0",
    "nodemon": "^3.1.0",
    "prisma": "^7.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
